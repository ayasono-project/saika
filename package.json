{
  "name": "saika",
  "version": "1.0.0",
  "description": "Discordサーバー管理Bot「彩加 =Saika=」",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "tsc-watch": "tsc --noEmit --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "format:check": "biome format src tests",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "typecheck:src": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "prepare": "husky"
  },
  "keywords": [
    "discord",
    "bot",
    "saika",
    "ayasono"
  ],
  "author": "sonozaki",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.4.0",
  "lint-staged": {
    "{src,tests}/**/*.ts": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ayasono/shared": "github:ayasono-project/shared#v0.2.4",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "date-fns": "^4.4.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "i18next": "^26.3.0",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.6",
    "@vitest/coverage-istanbul": "^4.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
