# ───────────────────────────────────────────
# Discord（必須）
# ───────────────────────────────────────────
DISCORD_TOKEN="BotのToken"
DISCORD_APP_ID="BotのApplication ID"
DISCORD_GUILD_ID="" # 開発用：テストサーバーのIDを設定するとコマンドが即座に反映されます
# DISCORD_ERROR_WEBHOOK_URL="https://discord.com/api/webhooks/{id}/{token}" # エラー通知用Webhook（任意）

# ───────────────────────────────────────────
# アプリ設定
# ───────────────────────────────────────────
LOCALE="ja"
# USER_MANUAL_URL="https://example.com/manual" # /help コマンドで表示（未設定時は省略）
# DASHBOARD_URL="https://saika-dash.sonozaki.net" # /help にダッシュボード案内を表示（未設定時は省略・本番稼働後に設定）
# OFFICIAL_URL="https://example.com" # /about に ayasono プロジェクト公式サイト（LP）を表示（未設定時は省略・LP 公開後に設定）

# ───────────────────────────────────────────
# データベース（PostgreSQL）
# ───────────────────────────────────────────
# ローカル開発は docker-compose.dev.yml の Postgres に接続する。
# 本番は Coolify の Environment Variables でマネージド DB の接続文字列を設定する。
DATABASE_URL="postgresql://saika:saika@localhost:5432/saika?schema=public"

# ───────────────────────────────────────────
# web ダッシュボード API（Bot と同一プロセスで起動する Fastify API）
# ───────────────────────────────────────────
# 認証は web BFF に集約し、saika はセッション JWT の「検証のみ」を行う
# （OAuth/refresh/Discord 呼び出しは持たない）。詳細は web/docs/specs/web/WEB_AUTH_SPEC.md。
#
# JWT 署名鍵（HMAC-SHA256）。web BFF と「完全に同一の値」を共有する。
# 本番は必須。未設定時は dev 固定鍵にフォールバック（ローカル検証のみ可）。
# JWT_SECRET=""
# CORS 許可オリジン（web ダッシュボードの配信元・カンマ区切りで複数可）。
# BFF が配信する SPA のオリジンに合わせる（ローカル E2E は http://localhost:3000）。
# WEB_ORIGIN="http://localhost:5173"
# API を起動するか（"false" で無効化・テスト/Bot 単体運用向け・未設定時は有効）。
# API_ENABLED="true"
# API のリッスンホスト（コンテナ内は 0.0.0.0）。
# API_HOST="0.0.0.0"
# API のリッスンポート。
# API_PORT="8080"

# ───────────────────────────────────────────
# 開発・テスト
# ───────────────────────────────────────────
# NODE_ENV="production"  # 実行環境（development / production / test）
# LOG_LEVEL="debug"      # Winston 標準: error / warn / info / http / verbose / debug / silly

# ── 非アクティブ自動キック ──
# INACTIVE_KICK_CRON_OVERRIDE="* * * * *"  # cron 上書き（毎分など・未設定時は毎時 0 分）
# INACTIVE_KICK_SKIP_GUARDS="true"          # runHour / lastRunDate ガードを無視して即時実行
# INACTIVE_KICK_DRY_RUN="true"             # キック実行をスキップ（通知のみ）
# INACTIVE_KICK_MOCK_MEMBERS="6"           # 実メンバー取得を省略してモックデータ N 件で通知 embed を確認

# ── 未承認ユーザー自動キック ──
# UNVERIFIED_KICK_CRON_OVERRIDE="* * * * *" # cron 上書き（未設定時は毎時 0 分）
# UNVERIFIED_KICK_SKIP_GUARDS="true"         # runHour / lastRunDate ガードを無視して即時実行
# UNVERIFIED_KICK_DRY_RUN="true"            # キック実行をスキップ（通知のみ）
# UNVERIFIED_KICK_MOCK_MEMBERS="6"          # 実メンバー取得を省略してモックデータ N 件で通知 embed を確認

# ── バンプリマインダー ──
# BUMP_REMINDER_TEST_MODE="true"  # タイマー短縮（120 分→1 分）+ 手動テストコマンド有効化（"test bump"/"test up"）
