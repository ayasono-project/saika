// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Guild Configuration
model GuildSettings {
  id             String   @id @default(cuid())
  guildId        String   @unique
  locale         String   @default("ja")
  errorChannelId String?  @map("error_channel_id")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guild_settings")
}

// Bump Reminder (Bump通知)
model BumpReminder {
  id          String   @id @default(cuid())
  guildId        String
  channelId      String   // 通知を送信するチャンネル
  messageId      String?  // 元のBumpメッセージID (返信用)
  panelMessageId String?  // Bumpパネルメッセージ ID (リマインダー送信後に削除)
  serviceName    String?  // サービス名 (Disboard, Dissoku)
  scheduledAt    DateTime // 通知予定時刻
  status         String   @default("pending") // pending, sent, cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId])
  @@index([status, scheduledAt])
  @@map("bump_reminders")
}

// 機能別設定テーブル（GuildSettings JSON カラムから分割）

// AFK設定
model GuildAfkSettings {
  guildId   String  @id @map("guild_id")
  enabled   Boolean @default(false)
  channelId String? @map("channel_id")

  @@map("guild_afk_settings")
}

// Bumpリマインダー設定
model GuildBumpReminderSettings {
  guildId        String  @id @map("guild_id")
  enabled        Boolean @default(false)
  channelId      String? @map("channel_id")
  mentionRoleId  String? @map("mention_role_id")
  mentionUserIds Json    @default("[]") @map("mention_user_ids") // jsonb: string[]

  @@map("guild_bump_reminder_settings")
}

// VAC（ボイスチャンネル自動作成）設定
model GuildVacSettings {
  guildId           String  @id @map("guild_id")
  enabled           Boolean @default(false)
  triggerChannelIds Json    @default("[]") @map("trigger_channel_ids") // jsonb: string[]
  createdChannels   Json    @default("[]") @map("created_channels")    // jsonb: VacChannelPair[]

  @@map("guild_vac_settings")
}

// メンバーログ設定
model GuildMemberLogSettings {
  guildId      String  @id @map("guild_id")
  enabled      Boolean @default(false)
  channelId    String? @map("channel_id")
  joinMessage  String? @map("join_message")
  leaveMessage String? @map("leave_message")

  @@map("guild_member_log_settings")
}

// VC自動募集設定
model GuildVcAutoRecruitSettings {
  guildId            String  @id @map("guild_id")
  enabled            Boolean @default(false)
  channelId          String? @map("channel_id")
  message            String?
  embedEnabled       Boolean @default(true) @map("embed_enabled")
  enabledCategoryIds Json    @default("[]") @map("enabled_category_ids") // jsonb: string[]（ルートは "TOP"）
  activeInvites      Json    @default("[]") @map("active_invites") // jsonb: VcAutoRecruitRef[]

  @@map("guild_vc_invite_settings")
}

// 非アクティブ自動キック設定
model GuildInactiveKickSettings {
  guildId          String    @id @map("guild_id")
  enabled          Boolean   @default(false)
  enabledAt        DateTime? @map("enabled_at") // 最後に有効化した時刻（キック起算の下限）
  channelId        String?   @map("channel_id")
  thresholdDays    Int       @default(30) @map("threshold_days")
  weekWarnMessage  String?   @map("week_warn_message") // 1週間前通知のカスタム文
  finalWarnMessage String?   @map("final_warn_message") // 最終警告（3日前）のカスタム文
  kickMessage      String?   @map("kick_message")
  markerRoleId     String?   @map("marker_role_id") // 警告対象へ自動付与する対象ロール ID
  whitelistRoleIds Json      @default("[]") @map("whitelist_role_ids") // jsonb: string[]
  whitelistUserIds Json      @default("[]") @map("whitelist_user_ids") // jsonb: string[]
  timezone         String    @default("Asia/Tokyo") // IANA タイムゾーン名
  runHour          Int       @default(4) @map("run_hour") // 実行時刻（0〜23）
  lastRunDate      String?   @map("last_run_date") // 同日2回実行ガード（"YYYY-MM-DD"）
  mentionEnabled   Boolean   @default(true) @map("mention_enabled") // 個別ユーザーメンション通知

  @@map("guild_inactive_kick_settings")
}

// メンバー活動履歴（非アクティブ自動キックの起算に使用）
model MemberActivity {
  id             String   @id @default(cuid())
  guildId        String   @map("guild_id")
  userId         String   @map("user_id")
  lastActivityAt DateTime @map("last_activity_at")
  warnStage      Int      @default(0) @map("warn_stage") // 0=未通知, 1=1週間前済, 2=最終警告済

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("member_activities")
}

// 未承認ユーザー自動キック設定
model GuildUnverifiedKickSettings {
  guildId         String    @id @map("guild_id")
  enabled         Boolean   @default(false)
  enabledAt       DateTime? @map("enabled_at") // 最後に有効化した時刻（キック起算の下限）
  verifiedRoleId  String?   @map("verified_role_id") // 認証ロール ID（保持していれば対象外）
  graceDays       Int       @default(7) @map("grace_days") // 参加からキックまでの猶予日数
  warnDays        Int?      @map("warn_days") // 事前警告を送る参加経過日数（null = 警告無効）
  notifyChannelId String?   @map("notify_channel_id") // キック予告チャンネル ID
  logChannelId    String?   @map("log_channel_id") // 監査ログチャンネル ID
  markerRoleId    String?   @map("marker_role_id") // 警告対象へ自動付与する対象ロール ID
  dmTemplate      String?   @map("dm_template") // カスタム警告 DM 本文
  notifyTemplate  String?   @map("notify_template") // カスタムキック予告本文（通知チャンネル）
  exemptRoleIds   Json      @default("[]") @map("exempt_role_ids") // jsonb: string[]
  timezone        String    @default("Asia/Tokyo") // IANA タイムゾーン名
  runHour         Int       @default(3) @map("run_hour") // 実行時刻（0〜23）
  lastRunDate     String?   @map("last_run_date") // 同日2回実行ガード（"YYYY-MM-DD"）
  mentionEnabled  Boolean   @default(true) @map("mention_enabled") // 個別ユーザーメンション通知

  @@map("guild_unverified_kick_settings")
}

// 未承認ユーザー自動キックの事前警告記録（メンバー単位・サイレントキック防止）
// warnedAt をもとに「警告済みか」「通知猶予が経過したか」を判定し、未警告者のキックを防ぐ。
model GuildUnverifiedKickWarn {
  guildId  String   @map("guild_id")
  userId   String   @map("user_id")
  warnedAt DateTime @map("warned_at") // 事前警告を送った時刻

  @@id([guildId, userId])
  @@index([guildId])
  @@map("guild_unverified_kick_warns")
}

// VC募集設定
model GuildVcRecruitSettings {
  guildId        String  @id @map("guild_id")
  enabled        Boolean @default(false)
  mentionRoleIds Json    @default("[]") @map("mention_role_ids") // jsonb: string[]
  setups         Json    @default("[]")                          // jsonb: VcRecruitSetup[]

  @@map("guild_vc_recruit_settings")
}

// Sticky Message (スティッキーメッセージ)
model StickyMessage {
  id            String   @id @default(cuid())
  guildId       String   @map("guild_id")
  channelId     String   @unique @map("channel_id")
  content       String
  embedData     Json?    @map("embed_data") // jsonb
  updatedBy     String?  @map("updated_by") // 最終設定・更新者の Discord ユーザーID
  lastMessageId String?  @map("last_message_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("sticky_messages")
}

// チケットチャンネル設定
model GuildTicketSettings {
  guildId          String  @map("guild_id")
  categoryId       String  @map("category_id")
  enabled          Boolean @default(false)
  staffRoleIds     Json    @default("[]") @map("staff_role_ids") // jsonb: string[]
  panelChannelId   String  @map("panel_channel_id")
  panelMessageId   String  @map("panel_message_id")
  panelTitle       String  @default("サポート") @map("panel_title")
  panelDescription String  @default("サポートが必要な場合は下のボタンからチケットを作成してください。") @map("panel_description")
  panelColor       String  @default("#00A8F3") @map("panel_color")
  autoDeleteDays   Int     @default(7) @map("auto_delete_days")
  maxTicketsPerUser Int    @default(1) @map("max_tickets_per_user")
  ticketCounter    Int     @default(0) @map("ticket_counter")

  @@id([guildId, categoryId])
  @@index([guildId])
  @@map("guild_ticket_settings")
}

// チケット
model Ticket {
  id              String    @id @default(cuid())
  guildId         String    @map("guild_id")
  categoryId      String    @map("category_id")
  channelId       String    @map("channel_id")
  userId          String    @map("user_id")
  ticketNumber    Int       @map("ticket_number")
  subject         String
  status          String    @default("open") // open, closed
  elapsedDeleteMs Int       @default(0) @map("elapsed_delete_ms")
  closedAt        DateTime? @map("closed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([guildId])
  @@index([categoryId])
  @@index([channelId])
  @@index([guildId, categoryId, userId, status])
  @@map("tickets")
}

// リアクションロールパネル
model GuildReactionRolePanel {
  id            String   @id @default(cuid())
  guildId       String   @map("guild_id")
  channelId     String   @map("channel_id")
  messageId     String   @map("message_id")
  mode          String   @default("toggle") // toggle, one-action, exclusive
  title         String   @default("ロール選択")
  description   String   @default("ボタンを押してロールを取得・解除できます。")
  color         String   @default("#00A8F3")
  buttons       Json     @default("[]") // jsonb: ReactionRoleButton[]
  buttonCounter Int      @default(0) @map("button_counter")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("guild_reaction_role_panels")
}
